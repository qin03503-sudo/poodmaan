# Environment Variables for Local Development

# ===== Database =====
# Identity Database (users, sessions, profiles)
IDENTITY_DB_HOST=localhost
IDENTITY_DB_PORT=5432
IDENTITY_DB_USER=postgres
IDENTITY_DB_PASSWORD=postgres
IDENTITY_DB_NAME=identity

# Catalog Database (podcasts, episodes, creators)
CATALOG_DB_HOST=localhost
CATALOG_DB_PORT=5433
CATALOG_DB_USER=postgres
CATALOG_DB_PASSWORD=postgres
CATALOG_DB_NAME=catalog

# Media Database (uploads, processing jobs)
MEDIA_DB_HOST=localhost
MEDIA_DB_PORT=5434
MEDIA_DB_USER=postgres
MEDIA_DB_PASSWORD=postgres
MEDIA_DB_NAME=media

# Library Database (follows, saves, playlists)
LIBRARY_DB_HOST=localhost
LIBRARY_DB_PORT=5435
LIBRARY_DB_USER=postgres
LIBRARY_DB_PASSWORD=postgres
LIBRARY_DB_NAME=library

# Billing Database (subscriptions, payments, payouts)
BILLING_DB_HOST=localhost
BILLING_DB_PORT=5436
BILLING_DB_USER=postgres
BILLING_DB_PASSWORD=postgres
BILLING_DB_NAME=billing

# Moderation Database (reports, cases)
MODERATION_DB_HOST=localhost
MODERATION_DB_PORT=5437
MODERATION_DB_USER=postgres
MODERATION_DB_PASSWORD=postgres
MODERATION_DB_NAME=moderation

# Analytics Database (events, metrics)
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5438
ANALYTICS_DB_USER=postgres
ANALYTICS_DB_PASSWORD=postgres
ANALYTICS_DB_NAME=analytics

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Kafka =====
KAFKA_BROKERS=localhost:9092
KAFKA_SCHEMA_REGISTRY=http://localhost:8081

# ===== S3/MinIO (Local Object Storage) =====
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=podcast-storage
S3_REGION=us-east-1

# ===== CDN (CloudFront for prod, local for dev) =====
CDN_BASE_URL=http://localhost:9000/podcast-storage
CDN_SIGNED_URL_SECRET=your-cdn-secret-change-in-prod
CDN_KEY_PAIR_ID=your-key-pair-id

# ===== JWT & Auth =====
JWT_SECRET=your-super-secret-jwt-key-change-in-prod
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_DAYS=30

# ===== OAuth Providers =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APPLE_CLIENT_ID=your-apple-client-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# ===== Payment Providers =====
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox  # or live

# Apple IAP
APPLE_IAP_SHARED_SECRET=your-apple-iap-shared-secret

# Google Play
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# ===== Email Service =====
EMAIL_PROVIDER=sendgrid  # or ses, mailgun
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@podcast-platform.com

# ===== Push Notifications =====
FIREBASE_SERVER_KEY=your-firebase-server-key
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apns-team-id
APNS_PRIVATE_KEY_PATH=path/to/apns-key.p8

# ===== Observability =====
# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Jaeger (Tracing)
JAEGER_ENABLED=true
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# OpenTelemetry
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# ===== Feature Flags =====
FEATURE_FLAGS_PROVIDER=unleash  # or launchdarkly
UNLEASH_API_URL=http://localhost:4242/api
UNLEASH_API_KEY=your-unleash-api-key

# ===== App URLs =====
WEB_APP_URL=http://localhost:3000
CREATOR_STUDIO_URL=http://localhost:3001
ADMIN_CONSOLE_URL=http://localhost:3002

# ===== Environment =====
NODE_ENV=development
LOG_LEVEL=debug  # debug, info, warn, error
